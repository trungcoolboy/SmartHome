[Unit]
Description=Smart Home API Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/home/trungcoolboy/SmartHome/backend
ExecStart=/usr/bin/python3 /home/trungcoolboy/SmartHome/backend/smart_home_api.py --host 0.0.0.0 --port 8090
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
